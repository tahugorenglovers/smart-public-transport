{
    "name": "smarttransit/php-citizen",
    "description": "Citizen Service - Smart Public Transport Platform",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.10",
        "php-amqplib/php-amqplib": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "config/database.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
