{
    "name": "smarttransit/traffic-service",
    "description": "Traffic Service - Smart Public Transport",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "php-amqplib/php-amqplib": "^3.6",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "classmap": ["tests/"]
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}